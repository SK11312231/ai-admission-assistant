# PostgreSQL connection string
# For local dev: postgresql://postgres:password@localhost:5432/admission
# On Railway: set this automatically — Railway Dashboard → your app service → Variables → Add Variable Reference → select Postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:PORT/railway

CLIENT_URL=https://ai-admission-assistant-production.up.railway.app/
OPENAI_API_KEY=your_key_here
WHATSAPP_API_TOKEN=your_key_here
WHATSAPP_VERIFY_TOKEN=your_key_here
PORT=3001
NODE_ENV=production
