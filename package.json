{
  "name": "ai-admission-assistant",
  "version": "1.0.0",
  "description": "AI-powered college/university admission assistant",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "admin"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=server && npm run build --workspace=client && npm run build --workspace=admin",
    "seed": "npm run seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}